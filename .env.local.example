# LLM API Keys (can also be set from the Settings page)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...

# Ollama (local SLM)
OLLAMA_BASE_URL=http://localhost:11434/api

# Database
DATABASE_PATH=./data/fitness.db

# Authentication (optional)
# Set a password to require login. Leave unset for local-only use.
# APP_PASSWORD=your-strong-password

# HTTPS (optional, used by `npm run start:https`)
# Required for PWA install when accessing from other devices.
# Certs can be generated with `tailscale cert` or mkcert.
# HTTPS_KEY_PATH=./certs/key.pem
# HTTPS_CERT_PATH=./certs/cert.pem
